# Copy this file to .env and fill in ALL values. Never commit .env.

# Key storage location — must be an absolute path outside the project source tree.
# Replace the placeholder below with the real absolute path on your system.
CRYPTO_KEY_DIR=/absolute/path/to/spy/runtime/keys

# Private key passphrases — ALL FOUR ARE REQUIRED.
# setup_keys.py will abort if any of these are missing or empty.
# Use strong, unique values. Do not leave these blank.
RSA_KEY_PASSPHRASE=
RSA_SIGN_KEY_PASSPHRASE=
ECC_KEY_PASSPHRASE=
ECC_SIGN_KEY_PASSPHRASE=

# Audit log path — MUST be an absolute path. Runtime rejects relative paths.
# A relative path resolves to the process CWD at launch time. If the process is launched
# from different directories (e.g. cron vs interactive), multiple independent chains are
# created and neither is complete. Replace the placeholder with the real absolute path.
AUDIT_LOG_PATH=/absolute/path/to/spy/audit_log.json

# User store HMAC secret — REQUIRED for authentication. Protects users.json integrity.
# Generate with: openssl rand -hex 32
# Never leave empty. Missing key fails closed.
USERS_HMAC_KEY=

# User store path — optional. Defaults to runtime/users.json.
# USERS_STORE_PATH=runtime/users.json

# Dashboard authentication secret — REQUIRED to access the Streamlit dashboard.
# Generate with: openssl rand -hex 32
DASHBOARD_SECRET=

# Workspace root — optional. Defaults to workspace/ inside the project directory.
# Override with an absolute path to use a different location.
SAFE_FILE_ROOT=

# OpenAI API key — only required if using the AI orchestrator with LLM context extraction.
OPENAI_API_KEY=
